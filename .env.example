# Google Maps Scraper - Environment Configuration
# Copy this file to .env and customize as needed

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# PUPPETEER / BROWSER CONFIGURATION
# ===========================================
# Run browser in headless mode (true/false)
HEADLESS=true

# Request timeout in milliseconds
REQUEST_TIMEOUT=60000

# ===========================================
# SCRAPER CONFIGURATION
# ===========================================
# Maximum scroll iterations per search
MAX_SCROLL_ITERATIONS=2000

# Scroll delay range (milliseconds)
SCROLL_DELAY_MIN=800
SCROLL_DELAY_MAX=1500

# Concurrent profile detail scraping
PROFILE_SCRAPE_CONCURRENCY=3

# Enable stealth mode for anti-detection
ENABLE_STEALTH=true

# Block heavy resources (images, videos)
BLOCK_RESOURCES=true

# Delay between requests (milliseconds)
MIN_DELAY_BETWEEN_REQUESTS=500
MAX_DELAY_BETWEEN_REQUESTS=1200

# ===========================================
# GEOGRAPHIC CHUNKING CONFIGURATION
# ===========================================
# Size of each grid tile in kilometers
GRID_SIZE_KM=3

# Overlap percentage between tiles (0-50)
TILE_OVERLAP_PERCENT=10

# City tiers to include (comma-separated)
# Options: metro, major, tier2, tier3
CITY_TIERS=metro,major,tier2,tier3

# Radius around city centers in kilometers
CITY_RADIUS_KM=15

# Include rural area tiles
INCLUDE_RURAL=false

# Scroll iterations before considering list complete
MAX_SCROLL_IDLE_COUNT=15

# Maximum retries per tile on failure
MAX_TILE_RETRIES=3

# ===========================================
# QUEUE CONFIGURATION
# ===========================================
# Maximum concurrent tile processing
CONCURRENCY=1

# Delay between tile processing (milliseconds)
TILE_DELAY_MIN=2000
TILE_DELAY_MAX=5000

# Batch size for auto-flush to disk
BATCH_FLUSH_SIZE=100

# ===========================================
# EXPORT CONFIGURATION
# ===========================================
# Output directory for exports
OUTPUT_DIR=./output

# Export format: json, csv, ndjson, all
EXPORT_FORMAT=all

# Include metadata in exports
INCLUDE_METADATA=true

# Pretty print JSON output
PRETTY_PRINT=true

# Filename prefix for exports
FILENAME_PREFIX=gmap_scrape

# ===========================================
# DEDUPLICATION CONFIGURATION
# ===========================================
# Enable phone-based deduplication
PHONE_DEDUP=true

# Enable coordinates-based deduplication
COORDS_DEDUP=true

# Coordinate precision for matching (decimal places)
COORDS_PRECISION=4

# ===========================================
# DATABASE CONFIGURATION (MongoDB)
# ===========================================
# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/gmap_scraper

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# Redis connection URL
REDIS_URL=redis://localhost:6379

# Redis host (alternative to URL)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache TTL in seconds
CACHE_TTL_PLACES=86400
CACHE_TTL_SEARCHES=3600

# ===========================================
# JOB QUEUE CONFIGURATION (BullMQ)
# ===========================================
# Number of concurrent scraping jobs
SCRAPE_CONCURRENCY=2

# Maximum jobs per minute (rate limit)
MAX_JOBS_PER_MINUTE=10

# Job retry attempts
JOB_RETRY_ATTEMPTS=3

# Job backoff delay (milliseconds)
JOB_BACKOFF_DELAY=5000

# ===========================================
# PHONE EXTRACTION
# ===========================================
# Enable deep phone extraction from detail pages
EXTRACT_PHONE_DETAILS=true

# Batch size for detail extraction
DETAIL_EXTRACTION_BATCH=10

# Delay between detail page visits (milliseconds)
DETAIL_EXTRACTION_DELAY=1500
